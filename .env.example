# ─── App ─────────────────────────────────────────────────────────────────────
# Local: http://localhost:3000  |  Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (Project Settings → API) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Supabase Postgres (Project Settings → Database) ─────────────────────────
# DATABASE_URL  = Connection pooling (Transaction mode, port 6543) — use in app + Vercel
# DIRECT_URL    = Direct connection (port 5432) — use for prisma db push / migrate
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── Resend (Fase 3 — ikke aktivert i prod ennå; Send e-post er kommentert ut i UI)
RESEND_API_KEY=
RESEND_FROM_EMAIL=faktura@dittfirma.no

# ─── Supabase Storage: opprett bucket "receipts" (private) for kvitteringer
